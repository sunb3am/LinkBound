# Copy to .env and fill in your values:
#   cp .env.example .env        (mac/linux)
#   copy .env.example .env      (Windows)
#
# .env is gitignored. Never commit real keys.

# Gemini API key (required for AI features: name cleanup, template generation,
# message tailoring, anti-AI review). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Comma-separated API keys accepted by the server for /api/v1/* endpoints.
# Pick any strong random strings; clients send one via the X-API-Key header.
OUTBOUND_API_KEYS=change_me_to_a_long_random_key

# Optional: used by client/mcp_server.py and external scripts (not read by the server).
# Must match one of the keys listed in OUTBOUND_API_KEYS above.
OUTBOUND_API_KEY=change_me_to_a_long_random_key

# Optional: base URL when running the MCP server or SDK against a non-default host.
OUTBOUND_BASE_URL=http://127.0.0.1:8000
